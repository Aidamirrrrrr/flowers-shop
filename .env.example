# Copy to .env
# Локально: docker compose up -d && pnpm db:setup
DATABASE_URL="postgresql://flowers:flowers@localhost:5433/flowers_shop?schema=public"
# Прод (Railway): задайте DATABASE_URL в Variables на дашборде Railway — не коммитьте в git
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?schema=public"
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
# Публичный HTTPS-URL мини-приложения (тот же, что в BotFather → Menu Button / Web App)
TELEGRAM_WEBAPP_URL="https://your-app.up.railway.app"
# Секрет для webhook: задайте и один раз вызовите POST /api/telegram/set-webhook?secret=...
TELEGRAM_WEBHOOK_SECRET="generate-a-long-random-string"
SESSION_SECRET="generate-a-long-random-string"
# Railway: volume mount path = /app/data (НЕ /app — иначе пропадёт package.json!)
# UPLOADS_DIR="/app/data/uploads/products"
