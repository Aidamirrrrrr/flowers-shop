# Copy to .env
# Локально: docker compose up -d && pnpm db:setup
DATABASE_URL="postgresql://flowers:flowers@localhost:5433/flowers_shop?schema=public"
# Прод (Railway): задайте DATABASE_URL в Variables на дашборде Railway — не коммитьте в git
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?schema=public"
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
SESSION_SECRET="generate-a-long-random-string"
# Railway volume mount: /app (фото сохраняются в public/uploads/products)
# UPLOADS_DIR="/app/public/uploads/products"
